{
  "plugins": ["remove-unreferenced-variables"],
  "rules": {
    "remove-unreferenced-variables": "on",
    "remove-useless-variables/remove": "on",
    "remove-useless-variables/declaration": "on",
    "return/remove-useless": "off",
    "convert-template-to-string": "off",
    "conditions/apply-consistent-blocks": "off",
    "esm/remove-empty-import": "off",
    "esm/sort-imports-by-specifiers": "off",
    "simplify-ternary/value": "off",
    "remove-useless-spread/object": "off",
    "return/simplify-boolean": "off",
    "types/convert-typeof-to-is-type": "off",
    "conditions/remove-boolean": "off",
    "for-of/for-each": "off",
    "apply-destructuring/object": "off",
    "apply-arrow": "off",
    "remove-unused-variables": "on",
    "remove-console": "off",
    "remove-useless-arguments/arguments": "off",
    "maybe/noop": "off",
    "conditions/remove-zero": "off",
    "conditions/merge-if-statements": "off",
    "apply-destructuring/array": "off",
    "new/remove-useless": "off",
    "regexp/optimize": "off",
    "esm/merge-duplicate-imports-join": "off",
    "conditions/remove-useless-else": "off",
    "optional-chaining/convert-logical-to-optional": "off",
    "conditions/convert-equal-to-strict-equal": "off",
    "for-of/for-in-positive": "off"
  }
}
